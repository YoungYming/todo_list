# Todo Server 环境变量示例
# 复制为 .env 后按需修改

# 数据落盘根目录（Docker 内一般为 /srv/data，本地可指向任意目录）
DATA_ROOT=/srv/data

# 可选：显式指定数据库 URL（不设则使用 DATA_ROOT/todo-server/todo.db）
# DATABASE_URL=sqlite:////srv/data/todo-server/todo.db

# 每日可用时长（分钟）
DAILY_AVAILABLE_MINUTES=120

# API 认证 Token（Bearer），供 OpenClaw 等调用；空则可不校验（仅建议内网使用）
API_TOKEN=

# 调试
DEBUG=false

# 服务监听（一般无需改）
# HOST=0.0.0.0
# PORT=8000

# 前端 API 基础路径（反向代理子路径时使用，如 /todo 则 API 为 /todo/api）
# API_BASE_PATH=

# LLM 拆分（可选，OpenAI 兼容）
SPLIT_LLM_ENABLED=false
# 可填 openclaw / opencode / local-openclaw，自动走本机 OpenClaw 兼容接口
SPLIT_LLM_BASE_URL=openclaw
# 留空时会尝试 OPENCODE_API_KEY / OPENCODE_ZEN_API_KEY / ~/.openclaw/openclaw.json token
SPLIT_LLM_API_KEY=
SPLIT_LLM_MODEL=openclaw:main
SPLIT_LLM_TIMEOUT_SECONDS=30
